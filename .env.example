# ============================================================================
# EliGraph — Variables d'environnement
# ============================================================================
# Copier ce fichier en `.env` et remplir les valeurs.
# Le fichier `.env` est gitignored — ne JAMAIS le committer.
# ============================================================================

# ----------------------------------------------------------------------------
# Mode de transport
# ----------------------------------------------------------------------------
# stdio : pour Claude Desktop (mode local, JSON-RPC sur stdin/stdout)
# http  : pour Claude.ai, Copilot Studio, et tout client MCP HTTP
ELIGRAPH_TRANSPORT=stdio

# ----------------------------------------------------------------------------
# App Registration Microsoft Entra
# ----------------------------------------------------------------------------
# Identifiants de l'App Registration EliGraph dans le tenant cible.
# Voir docs/setup-entra.md pour la procédure de création.
TENANT_ID=
CLIENT_ID=

# Secret utilisé UNIQUEMENT pour l'échange OBO côté serveur (mode HTTP).
# IMPORTANT : ce n'est PAS un mode app-only. Le secret authentifie EliGraph
# auprès d'Entra pour échanger un token utilisateur contre un token Graph
# au nom de l'utilisateur (delegated). Les permissions appliquées restent
# celles de l'utilisateur, pas celles de l'application.
CLIENT_SECRET=

# Alternative au secret : chemin vers un certificat PEM pour l'OBO.
# Si CERTIFICATE_PATH est défini, CLIENT_SECRET est ignoré.
# CERTIFICATE_PATH=/path/to/eligraph-cert.pem
# CERTIFICATE_PASSWORD=

# ----------------------------------------------------------------------------
# Sécurité — refus de l'app-only par défaut
# ----------------------------------------------------------------------------
# Par défaut, EliGraph refuse de démarrer en mode app-only (client_credentials).
# Ne passer à `true` que pour des cas exceptionnels (scripts d'admin, jobs
# planifiés sans utilisateur). Cette opt-in est logée explicitement au démarrage.
ELIGRAPH_ALLOW_APP_ONLY=false

# Liste des audiences acceptées pour les tokens entrants en mode HTTP/OBO.
# Format : api://<eligraph-client-id>/access_as_user
# Plusieurs valeurs possibles, séparées par des virgules.
ELIGRAPH_ALLOWED_AUDIENCES=

# ----------------------------------------------------------------------------
# Mode HTTP (uniquement si ELIGRAPH_TRANSPORT=http)
# ----------------------------------------------------------------------------
ELIGRAPH_HTTP_PORT=3000
ELIGRAPH_HTTP_HOST=0.0.0.0

# Redirect URI configurée dans l'App Registration Entra
ELIGRAPH_REDIRECT_URI=https://eligraph.example.com/auth/callback

# ----------------------------------------------------------------------------
# Audit & logging
# ----------------------------------------------------------------------------
# Niveau de log : trace, debug, info, warn, error, fatal
ELIGRAPH_LOG_LEVEL=info

# Chemin du fichier d'audit JSON. Si non défini, audit uniquement sur stdout.
# La rotation est gérée par logrotate côté OS, PAS par EliGraph.
ELIGRAPH_AUDIT_FILE=/var/log/eligraph/audit.log

# ----------------------------------------------------------------------------
# Microsoft Graph
# ----------------------------------------------------------------------------
# Si false : tous les appels Graph utilisent v1.0 (recommandé en prod).
# Si true (défaut Lokka) : utilise beta par défaut.
USE_GRAPH_BETA=false

# ----------------------------------------------------------------------------
# Variables historiques Lokka — gardées pour compatibilité, ignorées par défaut
# ----------------------------------------------------------------------------
# Ces variables existent dans Lokka upstream. EliGraph les ignore en mode
# délégué strict. Ne pas les utiliser sauf si ELIGRAPH_ALLOW_APP_ONLY=true.
# USE_INTERACTIVE=
# USE_CERTIFICATE=
# USE_CLIENT_TOKEN=
# ACCESS_TOKEN=
